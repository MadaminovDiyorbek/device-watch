# Mahalliy `npm start` / `node` uchun `agent/.env`
#
# Rasmiy Windows EXE (GitHub Actions `build:win`): foydalanuvchi .env yozmaydi —
# AGENT_SERVER_URL va AGENT_ENROLLMENT_KEY repository secrets orqali EXE ichiga qotiriladi.
#
# Cloud (oxirida / bo‘lmasin)
SERVER_URL=https://device-watch-server.onrender.com
ENROLLMENT_KEY=demo-enroll-secret
DEVICE_NAME=
DEVICE_TYPE=pc
DEVICE_LOCATION=Mahsulot ofisi
LOCAL_UI_PORT=47100
HEARTBEAT_SEC=5
